{
  "realm": "orderflow",
  "displayName": "OrderFlow",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,
  "defaultSignatureAlgorithm": "RS256",
  "revokeRefreshToken": true,
  "refreshTokenMaxReuse": 0,
  "accessTokenLifespan": 900,
  "accessTokenLifespanForImplicitFlow": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 28800,
  "offlineSessionIdleTimeout": 2592000,
  "accessCodeLifespan": 60,
  "accessCodeLifespanUserAction": 300,
  "accessCodeLifespanLogin": 1800,
  "actionTokenGeneratedByAdminLifespan": 43200,
  "actionTokenGeneratedByUserLifespan": 300,
  "passwordPolicy": "length(12) and upperCase(1) and lowerCase(1) and digits(1) and specialChars(1) and notUsername",
  "roles": {
    "realm": [
      {
        "name": "customer",
        "description": "Cliente final que pode realizar e consultar seus próprios pedidos."
      },
      {
        "name": "admin",
        "description": "Administrador da plataforma OrderFlow."
      },
      {
        "name": "service",
        "description": "Identidade de serviço para comunicação interna via client_credentials."
      }
    ]
  },
  "defaultRoles": ["customer"],
  "clients": [
    {
      "clientId": "orderflow-web",
      "name": "OrderFlow Web (frontend público)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "rootUrl": "http://localhost:3000",
      "redirectUris": [
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:3000"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "access.token.lifespan": "900"
      },
      "defaultClientScopes": [
        "web-origins",
        "profile",
        "roles",
        "email"
      ]
    },
    {
      "clientId": "order-service",
      "name": "Order Service (backend reativo, contexto Ordering)",
      "enabled": true,
      "publicClient": false,
      "secret": "order-service-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "attributes": {
        "access.token.lifespan": "900"
      }
    },
    {
      "clientId": "payment-service",
      "name": "Payment Service (autorização e captura)",
      "enabled": true,
      "publicClient": false,
      "secret": "payment-service-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "attributes": {
        "access.token.lifespan": "900"
      }
    },
    {
      "clientId": "inventory-service",
      "name": "Inventory Service (estoque e reservas)",
      "enabled": true,
      "publicClient": false,
      "secret": "inventory-service-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "attributes": {
        "access.token.lifespan": "900"
      }
    },
    {
      "clientId": "notification-service",
      "name": "Notification Service (email/SMS/push)",
      "enabled": true,
      "publicClient": false,
      "secret": "notification-service-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "attributes": {
        "access.token.lifespan": "900"
      }
    },
    {
      "clientId": "query-service",
      "name": "Query Service (modelos de leitura, CQRS)",
      "enabled": true,
      "publicClient": false,
      "secret": "query-service-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "attributes": {
        "access.token.lifespan": "900"
      }
    }
  ],
  "users": [
    {
      "username": "service-account-order-service",
      "enabled": true,
      "serviceAccountClientId": "order-service",
      "realmRoles": ["service"]
    },
    {
      "username": "service-account-payment-service",
      "enabled": true,
      "serviceAccountClientId": "payment-service",
      "realmRoles": ["service"]
    },
    {
      "username": "service-account-inventory-service",
      "enabled": true,
      "serviceAccountClientId": "inventory-service",
      "realmRoles": ["service"]
    },
    {
      "username": "service-account-notification-service",
      "enabled": true,
      "serviceAccountClientId": "notification-service",
      "realmRoles": ["service"]
    },
    {
      "username": "service-account-query-service",
      "enabled": true,
      "serviceAccountClientId": "query-service",
      "realmRoles": ["service"]
    }
  ]
}