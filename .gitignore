# =========================
# Java & Logs
# =========================
*.class
*.jar
*.war
*.ear
*.nar
# Keeps the Gradle wrapper safe, ignores other loose JARs.
!gradle/wrapper/gradle-wrapper.jar

# Avoid committing local logs generated by services.
*.log
logs/

# =========================
# Secrets & Local Settings
# =========================
# Essential for microservices: never commit Postgres passwords, JWT secrets, or Kafka credentials.
.env
.env.*
*.env
# If you use local Spring Boot profiles to override settings
application-local.yml
application-local.properties

# =========================
# Local Infrastructure
# =========================
# If any deployment script or Docker container generates local data in the root directory
.data/
data/
docker-compose.override.yml